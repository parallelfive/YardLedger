# Tare (YardLedger) web build for the test environment.
# Builds the Expo web export and serves it as a static SPA via nginx.
# The Supabase backend is baked in at build time via EXPO_PUBLIC_* build args.

FROM node:22-bookworm-slim AS build
ENV HUSKY=0
WORKDIR /app

COPY package.json package-lock.json ./
# The lockfile is not fully in sync and react 19 conflicts with a test-lib peer,
# so use install (not ci) with legacy peer resolution.
RUN npm install --legacy-peer-deps --no-audit --no-fund

COPY . .

ARG EXPO_PUBLIC_SUPABASE_URL
ARG EXPO_PUBLIC_SUPABASE_ANON_KEY
ENV EXPO_PUBLIC_SUPABASE_URL=$EXPO_PUBLIC_SUPABASE_URL
ENV EXPO_PUBLIC_SUPABASE_ANON_KEY=$EXPO_PUBLIC_SUPABASE_ANON_KEY

RUN npx expo export --platform web --output-dir dist-web

FROM nginx:alpine
COPY --from=build /app/dist-web /usr/share/nginx/html
COPY nginx.web.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
