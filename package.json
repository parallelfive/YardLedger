{
  "name": "yardledger",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@infinitered/react-native-mlkit-text-recognition": "^5.0.1",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-navigation/bottom-tabs": "^7.3.2",
    "@react-navigation/native": "^7.1.3",
    "@react-navigation/native-stack": "^7.3.2",
    "@reduxjs/toolkit": "^2.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "babel-preset-expo": "^55.0.10",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~55.0.5",
    "expo-dev-client": "~55.0.16",
    "expo-file-system": "~55.0.10",
    "expo-image-picker": "~55.0.12",
    "expo-linking": "~55.0.11",
    "expo-print": "~55.0.8",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.13",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-document-scanner-plugin": "^2.0.4",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-signature-canvas": "^5.0.2",
    "react-native-webview": "13.16.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "private": true
}
